@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":AddRejectCommandParser" as AddRejectCommandParser LOGIC_COLOR
participant "d:AddRejectCommand" as AddRejectCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("addreject 1 Failed technical interview")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("addreject 1 Failed technical interview")
activate AddressBookParser

create AddRejectCommandParser
AddressBookParser -> AddRejectCommandParser
activate AddRejectCommandParser

AddRejectCommandParser --> AddressBookParser
deactivate AddRejectCommandParser

AddressBookParser -> AddRejectCommandParser : parse("1 Failed technical interview")
activate AddRejectCommandParser

AddRejectCommandParser -> AddRejectCommandParser : parse arguments
activate AddRejectCommandParser #C8C8FA
AddRejectCommandParser --> AddRejectCommandParser : index
deactivate AddRejectCommandParser

AddRejectCommandParser -> AddRejectCommandParser : validate reason
activate AddRejectCommandParser #C8C8FA

alt#LightCoral #FFCCCC invalid format
    AddRejectCommandParser --> AddressBookParser : throw ParseException\n("Invalid format")
end

alt#LightCoral #FFCCCC invalid reason
    AddRejectCommandParser --> AddressBookParser : throw ParseException\n("Invalid reason")
end

AddRejectCommandParser --> AddRejectCommandParser
deactivate AddRejectCommandParser

create AddRejectCommand
AddRejectCommandParser -> AddRejectCommand : AddRejectCommand(index, reason)
activate AddRejectCommand

AddRejectCommand --> AddRejectCommandParser
deactivate AddRejectCommand

AddRejectCommandParser --> AddressBookParser : d
deactivate AddRejectCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
AddRejectCommandParser -[hidden]-> AddressBookParser
destroy AddRejectCommandParser

AddressBookParser --> LogicManager : d
deactivate AddressBookParser

LogicManager -> AddRejectCommand : execute(m)
activate AddRejectCommand

AddRejectCommand -> Model : getFilteredPersonList()
activate Model

Model --> AddRejectCommand : lastShownList
deactivate Model

alt#LightCoral #FFCCCC index out of range
    AddRejectCommand --> LogicManager : throw CommandException\n("Index out of range")
end

alt#LightCoral #FFCCCC candidate is blacklisted
    RejectCommand --> LogicManager : throw CommandException\n("Cannot modify blacklisted candidate")
end

AddRejectCommand -> AddRejectCommand : createRejectedPerson(person, reason)
activate AddRejectCommand #C8C8FA
note right
  Appends reason to
  rejection history
end note
AddRejectCommand --> AddRejectCommand : rejectedPerson
deactivate AddRejectCommand

AddRejectCommand -> Model : setPerson(person, rejectedPerson)
activate Model

Model --> AddRejectCommand
deactivate Model

create CommandResult
AddRejectCommand -> CommandResult
activate CommandResult

CommandResult --> AddRejectCommand
deactivate CommandResult

AddRejectCommand --> LogicManager : r
deactivate AddRejectCommand

[<--LogicManager
deactivate LogicManager
@enduml
