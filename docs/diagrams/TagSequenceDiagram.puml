@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":TagCommandParser" as TagCommandParser LOGIC_COLOR
participant "d:TagCommand" as TagCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("tag 1 at/Java")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("tag 1 at/Java")
activate AddressBookParser

create TagCommandParser
AddressBookParser -> TagCommandParser
activate TagCommandParser

TagCommandParser --> AddressBookParser
deactivate TagCommandParser

AddressBookParser -> TagCommandParser : parse(" 1 at/Java")
activate TagCommandParser

TagCommandParser -> TagCommandParser : parseIndices("1")
activate TagCommandParser #C8C8FA

alt#LightCoral #FFCCCC invalid index (non-positive or non-integer)
    TagCommandParser --> AddressBookParser : throw ParseException\n("Index is not a non-zero unsigned integer.")
end

alt#LightCoral #FFCCCC duplicate index (e.g. 1,1)
    TagCommandParser --> AddressBookParser : throw ParseException\n("Duplicate indices are not allowed.")
end

TagCommandParser --> TagCommandParser : indices = [Index(1)]
deactivate TagCommandParser

create TagCommand
TagCommandParser -> TagCommand : TagCommand(indices, tagsToAdd, tagsToDelete)
activate TagCommand

TagCommand --> TagCommandParser
deactivate TagCommand

TagCommandParser --> AddressBookParser : d
deactivate TagCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
TagCommandParser -[hidden]-> AddressBookParser
destroy TagCommandParser

AddressBookParser --> LogicManager : d
deactivate AddressBookParser

LogicManager -> TagCommand : execute(m)
activate TagCommand

TagCommand -> Model : getFilteredPersonList()
activate Model
Model --> TagCommand : lastShownList
deactivate Model

note over TagCommand
  Phase 2: Validate
  - add/delete conflict
  - duplicate tags within args
  - tags exist in master pool
  - candidate does not already
    hold added tags
  - candidate holds deleted tags
end note

alt#LightCoral #FFCCCC any Phase 2 validation failure
    TagCommand --> LogicManager : throw CommandException
end

TagCommand -> Model : setPerson(personToEdit, updatedPerson)
activate Model
Model --> TagCommand
deactivate Model

TagCommand -> Model : updateFilteredPersonList(PREDICATE_SHOW_ALL_PERSONS)
activate Model
Model --> TagCommand
deactivate Model

create CommandResult
TagCommand -> CommandResult
activate CommandResult
CommandResult --> TagCommand
deactivate CommandResult

TagCommand --> LogicManager : r
deactivate TagCommand

[<--LogicManager
deactivate LogicManager
@enduml
